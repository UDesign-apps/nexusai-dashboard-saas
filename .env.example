# NexusAI Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values

# Optional: Your AI provider API key for the AI Insights panel
# VITE_AI_API_KEY=sk-...

# Optional: Point to your real backend API
# VITE_API_BASE_URL=https://api.yourapp.com

# Optional: Disable mock data layer (default: true in dev)
# VITE_USE_MOCK=true
